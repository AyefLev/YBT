{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yanbeitong AI",
  "version": "0.1.0",
  "identifier": "com.yanbeitong.ai",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yanbeitong AI",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Yanbeitong AI desktop client",
    "longDescription": "Installable desktop client for Yanbeitong AI teaching and learning platform."
  }
}
